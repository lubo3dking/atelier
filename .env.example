# Copy to .env and fill in. The Anthropic SDK reads ANTHROPIC_API_KEY from the environment.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
# AGENT_MODEL=claude-opus-4-8
# AGENT_EFFORT=high
# AGENT_MAX_REVISIONS=3

# Memory backend: json (default, file-backed) or supabase
# AGENT_MEMORY_BACKEND=supabase
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_KEY=<service-role-key>   # server-side writes; keep secret
# SUPABASE_TABLE=runs

# --- Web app -----------------------------------------------------------------
# Public URL the app is reachable at (used for Stripe redirects + email links).
# ATELIER_PUBLIC_URL=https://your-domain.com
# ATELIER_RETENTION_DAYS=14      # auto-delete uploads + packs after N days
# ATELIER_BRAND=Atelier
# ATELIER_MAX_IMAGES=8
# ATELIER_MAX_IMAGE_MB=12

# --- Free public launch guards -----------------------------------------------
# Max generations per device per day (protects the API budget). 0 = unlimited.
# ATELIER_RATE_LIMIT_PER_DAY=10
# Owner key: visiting /?owner=<key> once makes that device unlimited & free
# forever (exempt from the rate limit and any future paywall). Keep it secret.
# ATELIER_OWNER_KEY=change-me-to-a-long-random-string

# --- Payments (optional; "sellable"). Unset = free & UNLIMITED, no paywall. --
# Model: a device gets ATELIER_FREE_PACKS free tech packs, then ONE payment
# (ATELIER_UNLOCK_CENTS) unlocks unlimited use forever.
# STRIPE_SECRET_KEY=sk_live_...
# ATELIER_FREE_PACKS=3           # free tech packs before the unlock prompt
# ATELIER_UNLOCK_CENTS=1999      # one-time unlock price, in cents (e.g. €19.99)
# ATELIER_CURRENCY=eur           # eur | usd | gbp | bgn

# --- Email (optional; "sendable"). Unset = download-only. --------------------
# RESEND_API_KEY=re_...
# ATELIER_EMAIL_FROM=Atelier <techpacks@your-domain.com>
